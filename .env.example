# Aikido Zen Firewall token for backend security monitoring
# Get your token from: https://app.aikido.dev/
AIKIDO_TOKEN=your_aikido_token_here

# Mapbox token for Fleet Map (live driver tracking)
# Get your token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Sentry - Error Tracking
VITE_SENTRY_DSN=

# PostHog - Product Analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft Clarity - Session Recording
VITE_CLARITY_PROJECT_ID=

# Resend - Transactional Email (replaces Klaviyo)
RESEND_API_KEY=

# Better Stack - Status Page
VITE_BETTERSTACK_STATUS_URL=
